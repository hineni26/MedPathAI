# Backend Configuration - Copy this to .env and fill in your values

# Supabase Database
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-or-service-key

# Google Gemini API
GEMINI_API_KEY=your-google-gemini-api-key

# Document Storage
DOCUMENT_BUCKET=medical-documents
DOCUMENT_EXTRACTION_ENABLED=false

# JWT Authentication (optional, for production)
JWT_SECRET=your-secret-key-change-in-production
JWT_TTL_SECONDS=86400

# PFL Officer Dashboard Access
PFL_OFFICER_API_KEY=optional-api-key-for-officer-dashboard

# Environment
DEBUG=false
LOG_LEVEL=INFO
